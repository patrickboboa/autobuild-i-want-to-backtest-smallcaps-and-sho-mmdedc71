# Polygon API Configuration
POLYGON_API_KEY=your_polygon_api_key_here

# Data Fetching Configuration
POLYGON_RATE_LIMIT_REQUESTS=5
POLYGON_RATE_LIMIT_PERIOD=60
POLYGON_MAX_RETRIES=3
POLYGON_RETRY_DELAY=5

# Cache Configuration
ENABLE_DATA_CACHE=True
CACHE_DIRECTORY=./cache

# Backtesting Configuration
START_DATE=2019-01-01
END_DATE=2024-01-01
INITIAL_CAPITAL=100000

# Short Selling Configuration
SHORT_BORROW_FEE_RATE=0.08
MARGIN_REQUIREMENT=1.5
HARD_TO_BORROW_FEE=0.15

# Slippage and Transaction Costs
SLIPPAGE_BPS=10
COMMISSION_PER_SHARE=0.005
MIN_COMMISSION=1.00

# Small Cap Criteria
MAX_MARKET_CAP=2000000000
MIN_MARKET_CAP=50000000
MIN_DAILY_VOLUME=100000
MIN_PRICE=1.00

# Risk Management
MAX_POSITION_SIZE_PCT=0.05
MAX_PORTFOLIO_EXPOSURE=1.0
STOP_LOSS_PCT=0.15
TAKE_PROFIT_PCT=0.25

# Data Management
CHUNK_SIZE_DAYS=90
MAX_CONCURRENT_STOCKS=50
MEMORY_LIMIT_MB=2048

# Logging
LOG_LEVEL=INFO
LOG_FILE=backtest.log